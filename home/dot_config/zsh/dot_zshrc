# vim: set ft=zsh :

# directories
mkdir -p "${XDG_STATE_HOME}/zsh"
mkdir -p "${XDG_CACHE_HOME}/zsh"
mkdir -p "${XDG_DATA_HOME}/zsh"

# history
HISTFILE="${XDG_STATE_HOME}/zsh/history"
HISTSIZE=10000
SAVEHIST=10000

setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt APPEND_HISTORY
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_SPACE
setopt HIST_NO_STORE
setopt HIST_REDUCE_BLANKS
setopt EXTENDED_HISTORY

# colors
autoload -Uz colors; colors
if command -v dircolors > /dev/null; then
    eval "$(dircolors -b)"
fi

# prompts
export PROMPT=$(echo -e "\n%B%F{blue}%~%f\n%F{%(?.002.red)}$ %f%b")
export PROMPT2=$(echo -e "%B%F{%?.002.red)}$ %f%b")
export PROMPT3=$(echo -e "%B%F{002}S$ %f%b")
export PROMPT4=$(echo -e "%B%F{002}[DEBUG(%:%I)] %f%b")

# completion
source "${XDG_DATA_HOME}/zsh/site/zsh-completions/zsh-completions.plugin.zsh"
autoload -Uz compinit; compinit
source "${XDG_DATA_HOME}/zsh/site/fzf-tab/fzf-tab.plugin.zsh"
zmodload zsh/complist
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' use-cache yes
zstyle ':completion:*' cache-path "${XDG_STATE_HOME}/zsh"
bindkey -M menuselect '^[[Z' reverse-menu-complete

# keybind
bindkey -v

# alias
# ls
if command -v eza > /dev/null; then
    alias ls='eza --long --color=auto --group-directories-first'
    alias la='eza --long --color=auto --almost-all --group-directories-first'
else
    alias ls='ls -l --color=auto --group-directories-first'
    alias la='ls -l --color=auto --almost-all --group-directories-first'
fi

# sudo
alias sudo='sudo '

# mkdir
alias mkdir='mkdir -p'

# cd
alias ..='cd ..'
alias ...='cd ../..'

# grep
alias grep='grep --color=auto'

# xdg-open
alias o='xdg-open'

# autosuggestions
source "${XDG_DATA_HOME}/zsh/site/zsh-autosuggestions/zsh-autosuggestions.zsh"

# syntax highlighting
source "${XDG_DATA_HOME}/zsh/site/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
