#!/usr/bin/env bash

set -o errexit -o pipefail -o noclobber -o nounset

# Useful functions
function msg() {
    echo "$(basename $0): $@"
}

function help() {
    cat <<EOS
Usage:
    $(basename $0) <operation> [option(s)] target(s)

Operations:
    -S --sync       Sync targets
    -R --remove     Remove targets
    -L --list       List targets

Options:
    -d --dry        Dry run
    -h --help       Print this message
EOS
}

# Check required programs
programs=("stow")
for program in ${programs[@]}; do
    if ! command -v $program &> /dev/null; then
        msg "$program could not be found"
        exit 1
    fi
done

getopt --test && true
if [ $? -ne 4 ]; then
    msg "getopt version should be 4"
    exit 1
fi

# Parse options
LONG_OPTIONS=sync,remove,list,dry,help
OPTIONS=SRLdh
PARSED=$(getopt --options=$OPTIONS --longoptions=$LONG_OPTIONS --name "$(basename $0)" -- "$@") || exit 1
eval set -- "$PARSED"

function check_operation() {
    if [ -n "$operation" ]; then
        msg "only one operation may be used at a time"
        exit 1
    fi
}

operation=
dry=0
while true; do
    case "$1" in
        -S|--sync)
            check_operation && operation="sync"
            shift
            ;;
        -R|--remove)
            check_operation && operation="remove"
            shift
            ;;
        -L|--list)
            check_operation && operation="list"
            shift
            ;;
        -d|--dry)
            dry=1
            shift
            ;;
        -h|--help)
            help
            exit 0
            ;;
        --)
            shift
            break
            ;;
        *)
            msg "program error"
            exit 1
            ;;
    esac
done

if [ -z "$operation" ]; then
    msg "no operation specified (use -h for help)"
    exit 1
fi

# Process operation
PACKAGE_DIR="$(cd "$(dirname "$0")"; [ -L "$0" ] && cd "$(dirname "$(readlink "$0")")"; cd ../../..; pwd)"

if [ "$operation" = "list" ]; then
    cd $PACKAGE_DIR
    ls
    exit 0
fi

case "$operation" in
    sync)
        OPERATION=-R ;;
    remove) 
        OPERATION=-D ;;
    *)        
        msg "program error" 
        exit 1 
        ;;
esac

if [ "$#" -eq 0 ]; then
    msg "no targets specified (use -h for help)"
    exit 1
fi

exec stow $OPERATION --dir="$PACKAGE_DIR" --target="/home/$USER" --verbose $([ $dry -eq 1 ] && echo "--simulate") --dotfiles "$@"
