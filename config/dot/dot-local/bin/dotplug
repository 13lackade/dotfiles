#!/usr/bin/env bash

set -o errexit -o pipefail -o noclobber -o nounset

# Useful functions
function msg() {
    echo "$(basename $0): $@"
}

# Check required programs
programs=("ruby")
for program in ${programs[@]}; do
    if ! command -v $program &> /dev/null; then
        msg "$program could not be found"
        exit 1
    fi
done

SCRIPT="$(cd "$(dirname "$0")"; [ -L "$0" ] && cd "$(dirname "$(readlink "$0")")"; cd ../share/dot/; pwd)/dotplug.rb"
ruby $SCRIPT $@
